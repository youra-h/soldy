{
  "name": "soldy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/ui/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev:vue": "npm run dev --workspace=@soldy/ui-vue",
    "dev:react": "npm run dev --workspace=@soldy/ui-react",
    "dev:angular": "npm run dev --workspace=@soldy/ui-angular",
    "dev:svelte": "npm run dev --workspace=@soldy/ui-svelte",
    "dev:solid": "npm run dev --workspace=@soldy/ui-solid",
    "test:core": "npm run test --workspace=@soldy/core",
    "test:plugins": "npm run test --workspace=@soldy/plugins",
    "test:vue": "npm run test --workspace=@soldy/ui-vue",
    "test:react": "npm run test --workspace=@soldy/ui-react",
    "test:angular": "npm run test --workspace=@soldy/ui-angular",
    "test:svelte": "npm run test --workspace=@soldy/ui-svelte",
    "test:solid": "npm run test --workspace=@soldy/ui-solid",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "~10.8.0",
    "prettier": "3.8.2",
    "typescript": "~6.0.2",
    "vite": "^6.0.0",
    "vite-svg-loader": "^5.1.1"
  }
}
