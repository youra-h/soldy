{
  "name": "soldy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "npm run dev --workspace=@soldy/ui-vue",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "vue-tsc --build"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "3.8.2",
    "typescript": "~6.0.2"
  }
}
